# ============================================================
# PostgreSQL Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Core Database Settings ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=app_db

# --- Connection Settings ---
# Port exposed on the host machine (EC2 instance)
POSTGRES_PORT=5432

# --- Resource Limits ---
# Shared memory size for PostgreSQL (recommended: 256MB+)
PG_SHARED_MEMORY=256m
# Docker memory limit for the PostgreSQL container
PG_MEMORY_LIMIT=3.5G
PG_MEMORY_RESERVATION=2G

# --- PgBouncer Connection Pooler ---
# Apps should connect to this port instead of POSTGRES_PORT for connection pooling
PGBOUNCER_PORT=6432

# --- Backup Settings ---
BACKUP_RETENTION_DAYS=7
BACKUP_CRON="0 2 * * *"
# Number of parallel jobs for backup/restore (match to CPU cores)
BACKUP_PARALLEL_JOBS=2

# --- PgAdmin (Optional Web UI) ---
PGADMIN_ENABLED=false
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=CHANGE_ME
PGADMIN_PORT=5050

# --- Monitoring (Optional) ---
# Set to 'true' to enable Prometheus exporter
MONITORING_ENABLED=false
EXPORTER_PORT=9187

